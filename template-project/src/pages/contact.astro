---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import FAQ from '@components/FAQ.astro';
import { SITE } from '@data/site.config';
---
<Layout title="Contact" path="/contact/"><Header /><main class="mx-auto max-w-3xl px-5 py-20"><h1 class="font-serif text-5xl">Get in touch</h1><p class="mt-4 text-ink-muted">{SITE.business.contact.phone.display}</p><a href={SITE.business.contact.whatsappUrl} class="mt-4 inline-block rounded-full bg-accent-500 px-6 py-2 text-white">WhatsApp</a><FAQ /></main><Footer /></Layout>
