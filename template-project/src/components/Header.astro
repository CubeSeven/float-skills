---
import { SITE } from '@data/site.config';
---
<header class="sticky top-0 z-40 border-b border-black/5 bg-surface/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href="/" class="font-serif text-xl font-semibold">{SITE.shortName}</a>
    <nav class="hidden gap-6 text-sm md:flex" aria-label="Main navigation">{SITE.nav.main.map((item) => <a class="hover:text-brand-600" href={item.href}>{item.label}</a>)}</nav>
    <button class="md:hidden" data-menu-toggle aria-label="Open navigation menu" aria-expanded="false">Menu</button>
  </div>
</header>
<div id="mobile-menu" class="mobile-overlay flex-col justify-center bg-brand-900 px-8 text-white">
  <button class="absolute right-5 top-5 h-11 w-11 rounded-full bg-white/10" data-menu-toggle aria-label="Close navigation menu">×</button>
  <nav class="flex flex-col gap-6 text-4xl font-serif" aria-label="Mobile navigation">{SITE.nav.main.map((item, index) => <a class="menu-link" style={`transition-delay:${index * 70}ms`} href={item.href}>{item.label}</a>)}</nav>
</div>
<script>
  const overlay = document.getElementById('mobile-menu');
  const toggles = document.querySelectorAll('[data-menu-toggle]');
  const close = () => { overlay?.classList.remove('open'); document.body.style.overflow = ''; toggles.forEach((b) => b.setAttribute('aria-expanded', 'false')); };
  toggles.forEach((button) => button.addEventListener('click', () => { const open = overlay?.classList.toggle('open'); document.body.style.overflow = open ? 'hidden' : ''; toggles.forEach((b) => b.setAttribute('aria-expanded', String(open))); }));
  overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape') close(); });
</script>
