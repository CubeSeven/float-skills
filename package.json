{
  "name": "float-skills",
  "version": "1.0.0",
  "private": true,
  "description": "Float Creatives brochure-website toolkit: portable AI agent rules, image pipeline scripts, and a self-contained Astro + Tailwind v4 starter template.",
  "type": "module",
  "bin": {
    "float-skills": "./bin/float-skills.mjs"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "sync-rules": "bash scripts/sync-rules.sh",
    "fetch-images": "node scripts/fetch-unsplash.mjs",
    "optimize-images": "node scripts/optimize-images.mjs",
    "process-images": "node scripts/process-images.mjs",
    "validate": "bash scripts/validate-project.sh",
    "post-setup": "bash scripts/generate-post-setup.sh"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "astro-icon": "^1.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "swiper": "^11.1.0",
    "glightbox": "^3.3.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "astro",
    "tailwindcss",
    "brochure-site",
    "float-creatives",
    "ai-agent-rules"
  ],
  "license": "MIT"
}
